<html lang="en">
<head>
<meta charset="UTF-8">
<title>Observer Pattern Refactoring Report</title>
<style>
  @page { margin: 2cm; }
  body {
    font-family: 'Segoe UI', Arial, sans-serif;
    line-height: 1.6;
    color: #1a1a1a;
    max-width: 800px;
    margin: 40px auto;
    padding: 0 20px;
  }
  h1 { color: #1a3c5e; border-bottom: 3px solid #1a3c5e; padding-bottom: 10px; font-size: 26px; }
  h2 { color: #2a5f8f; margin-top: 30px; font-size: 20px; }
  h3 { color: #3a7fbf; font-size: 16px; }
  .header-info { color: #555; font-size: 14px; margin-bottom: 30px; }
  table { border-collapse: collapse; width: 100%; margin: 15px 0; }
  th, td { border: 1px solid #ccc; padding: 10px 12px; text-align: left; font-size: 14px; }
  th { background-color: #1a3c5e; color: white; }
  tr:nth-child(even) { background-color: #f4f8fc; }
  code { background: #f0f4f8; padding: 2px 6px; border-radius: 3px; font-size: 13px; font-family: 'Consolas', monospace; }
  pre { background: #f0f4f8; padding: 14px; border-radius: 6px; overflow-x: auto; font-size: 13px; border-left: 4px solid #2a5f8f; }
  pre code { background: none; padding: 0; }
  .badge-new { background: #27ae60; color: white; padding: 2px 8px; border-radius: 4px; font-size: 12px; }
  .badge-modified { background: #e67e22; color: white; padding: 2px 8px; border-radius: 4px; font-size: 12px; }
  .badge-removed { background: #e74c3c; color: white; padding: 2px 8px; border-radius: 4px; font-size: 12px; }
